# ============================================================================
# AFRIJOB - Configuration d'Environnement
# ============================================================================
# Copie ce fichier en `.env` et remplis les valeurs

# ========== SERVER ==========
NODE_ENV=production
PORT=3000
API_BASE_URL=http://localhost:3000/api

# ========== DATABASE ==========
# MySQL
DB_HOST=localhost
DB_USER=afrijob_user
DB_PASSWORD=password123
DB_NAME=afrijob
DB_PORT=3306

# ========== JWT ==========
JWT_SECRET=your_super_secret_key_change_this_in_production_2024
JWT_EXPIRE=30d

# ========== RAILWAY (Déploiement) ==========
RAILWAY_TOKEN=your_railway_token_here
RAILWAY_API_KEY=your_railway_api_key_here

# ========== RENDER (Alternative) ==========
RENDER_DEPLOY_KEY=your_render_deploy_key_here

# ========== UPLOADS ==========
UPLOAD_DIR=uploads
MAX_FILE_SIZE=10000000

# ========== NOTIFICATIONS ==========
SEND_NOTIFICATIONS=true
NOTIFICATION_EMAIL=admin@afrijob.com

# ========== LOGGING ==========
LOG_LEVEL=info
