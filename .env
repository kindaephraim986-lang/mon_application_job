# ========================================
# 🔐 CONFIGURATION AFRIJOB - PRODUCTION
# ========================================

# ========================================
# 📊 ENVIRONNEMENT
# ========================================
NODE_ENV=production
DEBUG=false

# ========================================
# 🗄️ BASE DE DONNÉES
# ========================================
DB_HOST=localhost
DB_PORT=3306
DB_USER=afrijob_user
DB_PASSWORD=Ephi5729l
DB_NAME=bddiane_sp

# ========================================
# 🔑 AUTHENTIFICATION & SÉCURITÉ
# ========================================
JWT_SECRET=731fd0fb39c7399d30422a43fa75fa5e4ef803f9c41404dfd98e39ee3a2712ca6fe6ddfa61eddf09b8d7b6a21978608a957b453d096791e0e35c4664b927f304
JWT_EXPIRY=7d

FILE_SIGNATURE_SECRET=82e15e677c99fa21eb41ff7c75e56420750d58dbbea6e6f769d30cc9cb24ec3d
FILE_URL_EXPIRY=3600

# ========================================
# 🌐 SERVEUR
# ========================================
BACKEND_PORT=3001
FRONTEND_PORT=3000
BACKEND_URL=https://afrijob-backend.onrender.com
FRONTEND_URL=https://afrijob-frontend.onrender.com

# ========================================
# 💾 STOCKAGE DE FICHIERS
# ========================================
UPLOAD_DIR=./uploads
MAX_FILE_SIZE=10485760
PROFILE_PHOTO_DIR=./uploads/profile-photos
PROFILE_PHOTO_MAX_SIZE=5242880

# ========================================
# ☁️ STOCKAGE CLOUD (Optionnel)
# ========================================
USE_S3=false
AWS_REGION=eu-west-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
AWS_S3_BUCKET=afrijob-uploads
AWS_S3_URL=https://s3.amazonaws.com/afrijob-uploads

# ========================================
# 📧 EMAIL (Optionnel)
# ========================================
MAIL_HOST=smtp.gmail.com
MAIL_PORT=587
MAIL_USER=noreply@afrijob.com
MAIL_PASSWORD=
MAIL_FROM=AfriJob <noreply@afrijob.com>

# ========================================
# 💳 PAIEMENTS
# ========================================
PAYMENT_PROVIDER=stripe
STRIPE_SECRET_KEY=sk_test_your_stripe_key_here
STRIPE_PUBLISHABLE_KEY=pk_test_your_stripe_publishable_key_here

PAYPAL_MODE=sandbox
PAYPAL_CLIENT_ID=
PAYPAL_SECRET=

# ========================================
# 🔍 LOGS & MONITORING
# ========================================
LOG_LEVEL=info
LOG_FILE=/var/log/afrijob/backend.log
LOG_MAX_SIZE=10m
LOG_MAX_FILES=10

# ========================================
# 🔐 CORS & SESSIONS
# ========================================
CORS_ORIGIN=https://yourdomain.com
CORS_CREDENTIALS=true

SESSION_SECRET=40dfe8d0e2f0397b2a21244fc2d8ef3ba29be22805a3b4e903aeb05412df2622
SESSION_EXPIRY=2592000

# ========================================
# 🛡️ RATE LIMITING
# ========================================
RATE_LIMIT_WINDOW=15
RATE_LIMIT_MAX_REQUESTS=100

# ========================================
# 🚀 DÉPLOIEMENT DOCKER (Optionnel)
# ========================================
COMPOSE_PROJECT_NAME=afrijob
DOCKER_REGISTRY=docker.io
DOCKER_IMAGE_BACKEND=afrijob-backend
DOCKER_IMAGE_FRONTEND=afrijob-frontend
DOCKER_TAG=latest
